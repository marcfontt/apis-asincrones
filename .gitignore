# .gitignore
# ==============================================================================
# Arxiu per ignorar fitxers que NO haurien de sincronitzar-se al repositori Git.
# Aqui posem coses com variables d'entorn, artefactes de construccio, i fitxers
# especifics de la maquina del desenvolupador. Perfecte per a principiants!
# ==============================================================================

# === Fitxers del Sistema Operatiu ===
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
desktop.ini

# Linux
.directory

# === Logs i Fitxers de Debug ===
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# === Cobertura de Tests ===
coverage
.coverage
*.lcov
.nyc_output

# === Dependencles i Moduls ===
node_modules/
packages/*/node_modules

# === Arxius Yarn ===
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# === Directius de Construccio i Distribucio ===
dist
dist-types
build
*.tsbuildinfo

# === Fitxers d'Entorn (SECRETS!) ===
# IMPORTANT: No commits les credencials aqui!
.env
.env.local
.env.*.local
.env.test
.env.production.local

# === Editor i IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.editor
.editorconfig.local

# === Configuracio Local ===
*.local.yaml
*.local.json
.prettierrc.local
.eslintrc.local

# === Credencials i Secrets ===
*-credentials.yaml
*-credentials.json
*.pem
*.key
*.jks

# === VSCode Database ===
*.session.sql

# === Test Reports ===
e2e-test-report/
test-results/
playwright-report/

# === Cache ===
.cache/
.turbo/
.eslintcache
